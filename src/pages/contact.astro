---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ContactForm from "../components/ContactForm.tsx";
import FAQ from "../components/FAQ.astro";
import { business, whatsappHref, telHref } from "../data/business";

const breadcrumbs = [
  { name: "Home", href: "/" },
  { name: "Contact", href: "/contact/" },
];

const contactFaqs = [
  {
    q: "How soon can you come out?",
    a: "Free on-site assessment within 48 hours for most of Joburg North. Quote issued in writing within 48 hours of the visit. Emergencies (active leak) handled same week.",
  },
  {
    q: "What does a free quote include?",
    a: "Full on-site survey by a project lead, not a salesperson. Written itemised quote with materials, labour, timber work, and flashing priced separately. Alternatives where decisions are open (e.g. slate upgrade).",
  },
  {
    q: "Do you charge for the assessment?",
    a: "No. First on-site assessment and written quote are free. For emergency diagnostic call-outs we charge R1,800, credited against any remedial work we do.",
  },
  {
    q: "How quickly can you start the work?",
    a: "Emergency waterproofing: same week. Small repairs: 1-2 weeks. Full re-roofs: typically 4-8 weeks out depending on backlog and weather windows.",
  },
];

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  name: business.name,
  telephone: business.phoneE164,
  email: business.email,
  url: `${business.siteUrl}/contact/`,
  address: {
    "@type": "PostalAddress",
    streetAddress: business.address.line1,
    addressLocality: business.address.city,
    addressRegion: business.address.region,
    postalCode: business.address.postalCode,
    addressCountry: business.address.country,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: business.address.lat,
    longitude: business.address.lng,
  },
  openingHoursSpecification: business.hours
    .filter((h) => !h.closed)
    .map((h) => ({
      "@type": "OpeningHoursSpecification",
      dayOfWeek: h.day,
      opens: h.open,
      closes: h.close,
    })),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: contactFaqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<BaseLayout
  title="Contact Cederhof Roofing | Free Quote in 48 Hours"
  description="WhatsApp, phone, or form. Free on-site assessment within 48 hours across Joburg North. No obligation."
  schema={[contactSchema, faqSchema]}
  breadcrumbs={breadcrumbs}
>
  <section class="bg-muted">
    <div class="mx-auto max-w-[1280px] px-6 pb-16 pt-32 lg:px-10 lg:pb-20">
      <Breadcrumbs items={breadcrumbs} />
      <span class="mb-5 inline-block font-heading text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-accent">
        Contact
      </span>
      <h1 class="mb-6 font-heading text-foreground" style="font-size: clamp(2.25rem, 5vw, 4rem); font-weight: 700; line-height: 1.05;">
        Get a free roof assessment.
      </h1>
      <p class="max-w-2xl text-lg text-foreground/75 md:text-xl">
        Tell us what you need. We'll be on site within 48 hours with a written price within two days of the visit.
      </p>
    </div>
  </section>

  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
      <div class="grid gap-14 lg:grid-cols-[1.4fr_1fr] lg:gap-20">
        <div>
          <h2 class="text-foreground">Request a quote</h2>
          <p class="mt-3 text-foreground/70">
            The more context you give us, the sharper the quote. Photos help a lot, you can WhatsApp them directly to {business.whatsapp}.
          </p>
          <div class="mt-10">
            <ContactForm client:visible />
          </div>
        </div>

        <aside class="lg:pt-16">
          <div class="rounded-xl border border-border bg-muted p-8">
            <h3 class="mb-5 font-heading text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-accent">
              Or get in touch directly
            </h3>
            <ul class="space-y-4">
              <li>
                <a href={telHref()} class="group flex items-center gap-4 no-underline">
                  <span class="grid h-11 w-11 place-items-center rounded-full border border-border bg-background text-foreground/70 group-hover:text-accent">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path d="M22 16.92V20A2 2 0 0120 22A19 19 0 012 4A2 2 0 014 2H7.09A2 2 0 019 3.72L10.24 6.5A2 2 0 019.6 8.77L8 10A16 16 0 0014 16L15.23 14.4A2 2 0 0117.5 13.76L20.28 15A2 2 0 0122 16.92Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <div>
                    <p class="text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-foreground/50">Phone</p>
                    <p class="font-heading text-lg font-bold tabular-nums text-foreground group-hover:text-accent">{business.phone}</p>
                  </div>
                </a>
              </li>
              <li>
                <a href={whatsappHref()} rel="noopener" class="group flex items-center gap-4 no-underline">
                  <span class="grid h-11 w-11 place-items-center rounded-full border border-border bg-background text-foreground/70 group-hover:text-accent">
                    <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" fill="currentColor">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.149-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347z" />
                    </svg>
                  </span>
                  <div>
                    <p class="text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-foreground/50">WhatsApp</p>
                    <p class="font-heading text-lg font-bold tabular-nums text-foreground group-hover:text-accent">{business.whatsapp}</p>
                  </div>
                </a>
              </li>
              <li>
                <a href={`mailto:${business.email}`} class="group flex items-center gap-4 no-underline">
                  <span class="grid h-11 w-11 place-items-center rounded-full border border-border bg-background text-foreground/70 group-hover:text-accent">
                    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                      <path d="M3 7L12 13L21 7M5 19H19A2 2 0 0021 17V7A2 2 0 0019 5H5A2 2 0 003 7V17A2 2 0 005 19Z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <div>
                    <p class="text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-foreground/50">Email</p>
                    <p class="font-heading text-base font-bold text-foreground group-hover:text-accent">{business.email}</p>
                  </div>
                </a>
              </li>
            </ul>
          </div>

          <div class="mt-6 rounded-xl border border-border bg-background p-8">
            <h3 class="mb-5 font-heading text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-accent">
              Business hours
            </h3>
            <ul class="space-y-2 text-sm">
              {
                business.hours.map((h) => (
                  <li class="flex justify-between border-b border-border pb-2 last:border-b-0">
                    <span class="font-semibold text-foreground">{h.day}</span>
                    <span class="tabular-nums text-foreground/70">
                      {h.closed ? "Closed" : `${h.open} – ${h.close}`}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>

          <div class="mt-6 rounded-xl border border-border bg-background p-8">
            <h3 class="mb-3 font-heading text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-accent">
              Based in
            </h3>
            <address class="not-italic text-foreground">
              <p class="font-heading font-bold">{business.name}</p>
              <p class="mt-1 text-foreground/70">
                {business.address.line1}<br />
                {business.address.city}, {business.address.region}<br />
                {business.address.postalCode}<br />
                South Africa
              </p>
            </address>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-muted py-24 lg:py-32">
    <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
      <FAQ items={contactFaqs} eyebrow="Before you send" heading="The questions we answer first on most calls." />
    </div>
  </section>
</BaseLayout>
