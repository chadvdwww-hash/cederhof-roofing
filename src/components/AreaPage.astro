---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
import { business, whatsappHref, telHref } from "../data/business";
import { services } from "../data/services";
import { areas, type Area, getArea } from "../data/areas";
import { testimonials } from "../data/testimonials";
import { portfolio } from "../data/portfolio";

interface Props {
  area: Area;
}

const { area } = Astro.props;

const glob = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/stock/*.jpg",
  { eager: true }
);
function pick(f: string): ImageMetadata {
  return glob[`../assets/images/stock/${f}`].default;
}

const heroImg = pick(area.heroImage);

const suburbTestimonials = testimonials.filter((t) => t.suburb === area.name);
const suburbProjects = portfolio.filter((p) => p.suburb === area.name);

const nearbyAreas = area.nearbyAreas
  .map((slug) => getArea(slug))
  .filter((a): a is Area => !!a);

const areaSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  name: business.name,
  description: area.metaDescription,
  url: `${business.siteUrl}/areas/${area.slug}/`,
  telephone: business.phoneE164,
  priceRange: business.priceRange,
  address: {
    "@type": "PostalAddress",
    streetAddress: business.address.line1,
    addressLocality: business.address.city,
    addressRegion: business.address.region,
    postalCode: business.address.postalCode,
    addressCountry: business.address.country,
  },
  areaServed: {
    "@type": "Place",
    name: `${area.name}, Johannesburg`,
  },
};

const breadcrumbs = [
  { name: "Home", href: "/" },
  { name: "Areas", href: "/areas/" },
  { name: area.name, href: `/areas/${area.slug}/` },
];
---

<BaseLayout title={area.title} description={area.metaDescription} schema={areaSchema} breadcrumbs={breadcrumbs}>
  <section class="relative min-h-[70dvh] overflow-hidden">
    <Image
      src={heroImg}
      alt={`Residential home in ${area.name}, Johannesburg North, showing a carefully finished roof`}
      widths={[640, 1024, 1600, 2200]}
      sizes="100vw"
      quality={84}
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-primary-dark via-primary-dark/80 to-primary-dark/30" aria-hidden="true"></div>

    <div class="relative mx-auto flex min-h-[70dvh] max-w-[1280px] flex-col justify-end px-6 pb-20 pt-32 lg:px-10">
      <div class="max-w-3xl">
        <span class="mb-5 inline-flex items-center gap-2 rounded-full border border-on-dark/25 bg-on-dark/5 px-4 py-1.5 text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-on-dark/85 backdrop-blur">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          {area.priority === "P1" ? "Primary area" : "Secondary area"} · {area.kmFromBase} km from base
        </span>
        <h1 class="mb-5 font-heading text-on-dark" style="font-size: clamp(2.25rem, 5vw, 4rem); font-weight: 700; line-height: 1.05;">
          {area.h1}
        </h1>
        <p class="max-w-2xl text-lg text-on-dark/75 md:text-xl">{area.subheadline}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact/" class="inline-flex items-center gap-2 rounded-md bg-accent px-6 py-4 text-base font-semibold text-on-primary no-underline transition-all duration-200 hover:bg-accent-hover active:scale-[0.98]">
            Request a quote for {area.name}
          </a>
          <a href={whatsappHref(`Hi Cederhof, I'd like a free roof assessment in ${area.name}.`)} rel="noopener" class="inline-flex items-center gap-2 rounded-md border border-on-dark/25 bg-on-dark/5 px-6 py-4 text-base font-semibold text-on-dark no-underline backdrop-blur transition-all duration-200 hover:bg-on-dark/10">
            WhatsApp {business.whatsapp}
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
      <Breadcrumbs items={breadcrumbs} />

      <div class="grid gap-14 lg:grid-cols-[1.2fr_1fr] lg:gap-20">
        <div>
          <span class="mb-3 inline-block font-heading text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-accent">
            About roofing in {area.name}
          </span>
          <h2 class="text-foreground">{area.name} homes, by {business.name}.</h2>
          <p class="mt-6 text-lg leading-relaxed text-foreground/75">{area.intro}</p>
          <p class="mt-5 text-foreground/70">{area.localContext}</p>
        </div>

        <aside class="rounded-xl border border-border bg-muted p-8">
          <h3 class="mb-5 font-heading text-[0.72rem] font-semibold uppercase tracking-[0.16em] text-accent">
            {area.name} typical brief
          </h3>
          <dl class="space-y-4">
            <div>
              <dt class="text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-foreground/50">
                Property stock
              </dt>
              <dd class="mt-1 text-foreground">{area.typicalProperty}</dd>
            </div>
            <div>
              <dt class="text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-foreground/50">
                Common architectural styles
              </dt>
              <dd class="mt-1 flex flex-wrap gap-1.5">
                {
                  area.architecturalStyles.map((s) => (
                    <span class="inline-flex rounded-full border border-border bg-background px-3 py-1 text-xs text-foreground">
                      {s}
                    </span>
                  ))
                }
              </dd>
            </div>
            <div>
              <dt class="text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-foreground/50">
                Distance from base
              </dt>
              <dd class="mt-1 font-heading text-lg font-bold tabular-nums text-foreground">
                {area.kmFromBase} km
              </dd>
            </div>
          </dl>
        </aside>
      </div>
    </div>
  </section>

  <section class="bg-muted py-24 lg:py-32">
    <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-heading text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-accent">
          Services available in {area.name}
        </span>
        <h2 class="text-foreground">Every service, delivered in your suburb.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s, i) => (
            <a
              href={`/services/${s.slug}/`}
              class="group flex flex-col justify-between rounded-lg border border-border bg-background p-7 no-underline transition-all duration-200 hover:border-accent/50 hover:-translate-y-1"
            >
              <div>
                <span class="font-heading text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-accent">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h3 class="mt-3 font-heading text-[1.3rem] font-bold leading-tight text-foreground">
                  {s.name}
                </h3>
                <p class="mt-3 text-sm text-foreground/70">{s.short}</p>
              </div>
              <span class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-foreground transition-colors group-hover:text-accent">
                Learn more
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" class="transition-transform group-hover:translate-x-1"><path d="M5 12H19M13 6L19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" /></svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  {
    (suburbTestimonials.length > 0 || suburbProjects.length > 0) && (
      <section class="py-24 lg:py-32">
        <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
          <div class="mb-12 max-w-2xl">
            <span class="mb-3 inline-block font-heading text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-accent">
              Local proof
            </span>
            <h2 class="text-foreground">Work we've completed in {area.name}.</h2>
          </div>
          {suburbTestimonials.length > 0 && (
            <div class="mb-12 grid gap-6 md:grid-cols-2">
              {suburbTestimonials.slice(0, 2).map((t) => (
                <blockquote class="rounded-xl border border-border bg-muted p-8">
                  <div class="mb-4 flex gap-0.5 text-accent" aria-label={`${t.rating} out of 5 stars`}>
                    {Array.from({ length: t.rating }).map(() => (
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
                        <path d="M12 2L14.39 8.25L21 9.27L16.5 13.97L17.77 20.5L12 17.27L6.23 20.5L7.5 13.97L3 9.27L9.61 8.25L12 2Z" />
                      </svg>
                    ))}
                  </div>
                  <p class="font-heading text-lg font-medium leading-snug text-foreground">"{t.text}"</p>
                  <footer class="mt-5 border-t border-border pt-4 text-sm">
                    <p class="font-heading font-bold text-foreground">{t.name}</p>
                    <p class="text-foreground/60">{t.service} · {t.date}</p>
                  </footer>
                </blockquote>
              ))}
            </div>
          )}
          {suburbProjects.length > 0 && (
            <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
              {suburbProjects.slice(0, 3).map((p) => (
                <figure class="overflow-hidden rounded-lg border border-border bg-muted">
                  <Image
                    src={pick(p.image)}
                    alt={`${p.service} on ${p.propertyType} in ${p.suburb} by Cederhof Roofing`}
                    widths={[400, 600, 800]}
                    sizes="(min-width: 1024px) 33vw, 100vw"
                    quality={84}
                    loading="lazy"
                    class="aspect-[4/3] w-full object-cover"
                  />
                  <figcaption class="p-5">
                    <p class="font-heading font-semibold text-foreground">{p.propertyType}</p>
                    <p class="mt-1 text-sm text-foreground/70">{p.service} · {p.material}</p>
                    <p class="mt-3 text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-foreground/40">{p.date}</p>
                  </figcaption>
                </figure>
              ))}
            </div>
          )}
        </div>
      </section>
    )
  }

  <section class="bg-muted py-24 lg:py-32">
    <div class="mx-auto max-w-[1280px] px-6 lg:px-10">
      <div class="mb-12 max-w-2xl">
        <span class="mb-3 inline-block font-heading text-[0.7rem] font-semibold uppercase tracking-[0.16em] text-accent">
          Nearby areas
        </span>
        <h2 class="text-foreground">We cover your neighbours too.</h2>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {
          nearbyAreas.map((n) => (
            <a
              href={`/areas/${n.slug}/`}
              class="group flex items-center justify-between gap-4 rounded-lg border border-border bg-background p-6 no-underline transition-all duration-200 hover:border-accent/50"
            >
              <div>
                <h3 class="font-heading text-lg font-bold text-foreground">{n.name}</h3>
                <p class="mt-1 text-sm text-foreground/60">{n.kmFromBase} km from base</p>
              </div>
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" class="text-foreground/40 transition-transform group-hover:translate-x-1"><path d="M9 6L15 12L9 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" /></svg>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-primary-dark text-on-dark">
    <div class="mx-auto grid max-w-[1280px] gap-12 px-6 py-24 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center lg:gap-20 lg:px-10 lg:py-28">
      <div class="w-full max-w-[680px]">
        <span class="mb-5 inline-block font-heading text-[0.72rem] font-semibold uppercase tracking-[0.22em] text-accent">
          Free quote in 48 hours
        </span>
        <h2
          class="text-on-dark"
          style="font-size: clamp(1.9rem, 3vw, 2.5rem); line-height: 1.2; letter-spacing: -0.005em;"
        >
          Free roof assessment in {area.name} within 48 hours.
        </h2>
        <p class="mt-7 text-lg leading-[1.75] text-on-dark/75" style="max-width: 56ch;">
          No obligation, no pushy sales, just an honest look at the work and a written price within two days.
        </p>
      </div>
      <div class="flex w-full flex-col gap-3 sm:flex-row lg:w-auto lg:flex-shrink-0 lg:flex-col xl:flex-row">
        <a href="/contact/" class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md bg-accent px-6 py-4 font-heading text-sm font-bold uppercase tracking-[0.1em] text-on-primary no-underline transition-all duration-200 hover:bg-accent-hover active:scale-[0.98]">
          Request a quote
        </a>
        <a href={telHref()} class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border border-on-dark/25 bg-on-dark/5 px-6 py-4 font-heading text-sm font-bold uppercase tracking-[0.1em] text-on-dark no-underline backdrop-blur transition-all duration-200 hover:bg-on-dark/10">
          Call {business.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
