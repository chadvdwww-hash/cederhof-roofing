---
import MobileNav from "./MobileNav.tsx";
import { business, telHref } from "../data/business";
import { services } from "../data/services";
import { areas } from "../data/areas";

const nav = [
  { label: "Services", href: "/services/" },
  { label: "Portfolio", href: "/portfolio/" },
  { label: "Areas", href: "/areas/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const servicesFlat = services.map((s) => ({ label: s.name, href: `/services/${s.slug}/` }));
const areasFlat = areas.map((a) => ({ label: a.name, href: `/areas/${a.slug}/` }));
---

<header
  class="sticky top-0 z-40 border-b border-border/60 bg-background/85 backdrop-blur supports-[backdrop-filter]:bg-background/70"
>
  <div class="mx-auto flex max-w-[1280px] items-center justify-between px-6 py-4 lg:px-10">
    <a
      href="/"
      class="group flex items-center gap-3 text-foreground no-underline"
      aria-label={`${business.name} home`}
    >
      <span class="relative grid h-11 w-11 place-items-center overflow-hidden rounded-md bg-primary text-accent shadow-[0_4px_14px_-6px_rgba(15,15,15,0.45)]">
        <svg
          viewBox="0 0 48 48"
          width="28"
          height="28"
          aria-hidden="true"
          class="relative z-10"
        >
          <path
            d="M7 30 L24 12 L41 30"
            fill="none"
            stroke="currentColor"
            stroke-width="3.6"
            stroke-linejoin="round"
            stroke-linecap="round"
          />
          <path
            d="M14 30 L24 20 L34 30"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linejoin="round"
            stroke-linecap="round"
            opacity="0.55"
          />
          <path
            d="M9 36 L39 36"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
          />
        </svg>
        <span
          class="absolute -right-2 -top-2 h-5 w-5 rounded-full bg-accent/15 blur-sm"
          aria-hidden="true"
        ></span>
      </span>
      <span class="flex flex-col leading-none">
        <span class="font-heading text-[0.55rem] font-bold uppercase tracking-[0.28em] text-foreground/55">
          Est. {business.established}
        </span>
        <span class="mt-1 font-heading text-[1.15rem] font-black uppercase tracking-[-0.015em] text-foreground">
          {business.name}
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-foreground/80 transition-colors hover:text-accent"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a
        href={telHref()}
        class="text-sm font-medium tabular-nums text-foreground/80 hover:text-accent"
        aria-label={`Call ${business.phone}`}
      >
        {business.phone}
      </a>
      <a
        href="/contact/"
        class="inline-flex items-center gap-2 rounded-md bg-accent px-4 py-2.5 text-sm font-semibold text-on-primary transition-all duration-200 hover:bg-accent-hover active:scale-[0.98] active:translate-y-px"
      >
        Get a free quote
      </a>
    </div>

    <MobileNav client:visible nav={nav} services={servicesFlat} areas={areasFlat} />
  </div>
</header>
