---
interface Props {
  slug: string;
  name: string;
  short: string;
  number: string;
}

const { slug, name, short, number } = Astro.props;
---

<a
  href={`/services/${slug}/`}
  class="group relative flex flex-col justify-between rounded-lg border border-border bg-background p-7 no-underline transition-all duration-200 hover:border-accent/50 hover:-translate-y-1 hover:shadow-[0_18px_30px_-20px_rgba(23,23,23,0.25)] focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-4 focus:ring-offset-background"
>
  <div>
    <span class="font-heading text-[0.72rem] font-semibold uppercase tracking-[0.18em] text-accent">
      {number}
    </span>
    <h3 class="mt-3 font-heading text-[1.4rem] font-bold leading-tight text-foreground">
      {name}
    </h3>
    <p class="mt-3 text-foreground/70">{short}</p>
  </div>
  <span class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-foreground transition-colors group-hover:text-accent">
    Learn more
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" class="transition-transform group-hover:translate-x-1">
      <path d="M5 12H19M13 6L19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
    </svg>
  </span>
</a>
