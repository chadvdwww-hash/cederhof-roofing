---
import "../styles/globals.css";
import SEOHead from "../components/SEOHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | object[];
  breadcrumbs?: { name: string; href: string }[];
}

const { title, description, canonical, ogImage, noindex, schema, breadcrumbs } =
  Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
      schema={schema}
      breadcrumbs={breadcrumbs}
    />
  </head>
  <body class="bg-background text-foreground antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-primary focus:text-on-primary focus:px-4 focus:py-2 focus:rounded-md"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
